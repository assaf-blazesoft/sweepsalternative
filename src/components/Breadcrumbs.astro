---
interface Props {
  crumbs: { name: string; path: string }[];
}
const { crumbs } = Astro.props;
---
<nav aria-label="Breadcrumb" class="container-x pt-8">
  <ol class="flex flex-wrap items-center gap-2 mono-meta">
    {crumbs.map((c, i) => (
      <li class="flex items-center gap-2">
        {i > 0 && <span aria-hidden="true" class="text-ink-muted/50">/</span>}
        {i < crumbs.length - 1 ? (
          <a href={c.path} class="hover:text-ink">{c.name}</a>
        ) : (
          <span class="text-ink" aria-current="page">{c.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
