---
import Base from '../layouts/Base.astro';
import USMap from '../components/USMap.astro';
import EmailCapture from '../components/EmailCapture.astro';
import PlatformRow from '../components/PlatformRow.astro';
import { SITE } from '../config';
import {
  STAT_BANNED_COUNT,
  LAST_UPDATED,
  bannedStates,
  restrictedStates,
  atRiskStates,
} from '../data/states';
import { PLATFORMS } from '../data/platforms';
import { websiteSchema, faqSchema, itemListSchema } from '../lib/schema';

const title = `Legal Sweepstakes Alternatives for Banned US States | ${SITE.name}`;
const description =
  "Your sweepstakes casino stopped working? See the four legal alternatives still open to players in banned US states, with honest risk ratings and a live ban map.";

const faqs = [
  {
    q: 'My sweepstakes casino stopped working. What happened?',
    a: "Your state banned the dual-currency sweepstakes model, so the legit operators packed up and left. You didn't do anything wrong, the rules changed. Other kinds of play are still perfectly legal.",
  },
  {
    q: 'What can I actually play now?',
    a: "Four platforms cover most of the post-ban landscape: CardCrush, Horseplay, Albumza, and Clash5. They run on different legal models (single-currency or parimutuel), and we tell you which work in your state.",
  },
  {
    q: 'How do I know these alternatives are safe?',
    a: "We check how each platform stays legal, where it's available, and how risky it is, and we tell you plainly. If we can't confirm something is legit, we say so instead of pushing you toward it.",
  },
];

const stateGroups = [
  { label: 'Banned', states: bannedStates },
  { label: 'Restricted', states: restrictedStates },
  { label: 'At risk', states: atRiskStates },
];

const itemList = itemListSchema({
  name: 'Legal sweepstakes casino alternatives',
  items: PLATFORMS.map((p) => ({
    name: p.name,
    url: `${SITE.url}/review/${p.slug}`,
    description: p.blurb,
  })),
});

const schema = [websiteSchema(), faqSchema(faqs), itemList];
---
<Base title={title} description={description} schema={schema} canonical="/" showDisclosure>
  <!-- Hero: tight, scannable, leads straight into the alternatives -->
  <section class="relative overflow-hidden border-b border-surface-border">
    <div
      aria-hidden="true"
      class="pointer-events-none absolute left-1/2 top-0 -z-10 h-[420px] w-[680px] max-w-[120vw] -translate-x-1/2 -translate-y-1/3 rounded-full bg-brand-green/10 blur-3xl"
    ></div>

    <div class="container-x py-10 text-center lg:py-14">
      <p class="mono-meta uppercase tracking-widest text-brand-green">
        Updated {LAST_UPDATED} · {STAT_BANNED_COUNT} states affected
      </p>
      <h1 class="mx-auto mt-3 max-w-3xl text-h1">
        Sweepstakes casino stopped working?
        <span class="bg-gradient-to-r from-brand-green to-brand-gold bg-clip-text text-transparent">
          Here's what still works.
        </span>
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-body text-ink-muted">
        Sweep-style platforms still open where dual-currency sweepstakes got banned. Ranked, vetted, updated monthly.
      </p>
      <p class="mt-5 text-meta text-ink-muted">
        By <a href="/about" class="text-accent hover:underline font-medium">{SITE.author}</a>
        · <a href="/methodology" class="hover:underline">How we rank →</a>
      </p>
    </div>
  </section>

  <!-- Alternatives: results-first, ranked row layout, no filters above the fold -->
  <section class="container-x pt-12 pb-6" aria-labelledby="alternatives-heading">
    <h2 id="alternatives-heading" class="text-h2">Where to play instead</h2>
    <p class="mt-2 max-w-prose text-ink-muted">
      Four sweep-style platforms still open in banned states. Ranked by how solid each one stands and how broadly it works today.
    </p>
    <div class="mt-8 space-y-7">
      {PLATFORMS.map((p, i) => <PlatformRow platform={p} rank={i + 1} pillStates={['CA', 'NY']} eager={i === 0} />)}
    </div>

    <!-- Optional state picker, kept secondary -->
    <form id="state-picker" class="mx-auto mt-10 flex w-full max-w-md flex-col gap-2 sm:flex-row" aria-label="Show alternatives for a specific state">
      <label class="sr-only" for="state-select">Filter by state</label>
      <select
        id="state-select"
        class="field-select flex-1 rounded-lg border border-surface-border bg-surface px-4 py-2.5 text-sm text-ink transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
      >
        <option value="" selected disabled>Pick your state for state-specific guidance…</option>
        {stateGroups.map((g) => (
          <optgroup label={g.label}>
            {g.states.map((s) => <option value={s.slug}>{s.name}</option>)}
          </optgroup>
        ))}
      </select>
      <button type="submit" class="btn-primary px-5 py-2.5 text-sm whitespace-nowrap">Go</button>
    </form>
    <p class="mt-3 text-center mono-meta">
      <a href="/alternatives" class="text-accent hover:underline">See every option with filters →</a>
    </p>
  </section>

  <!-- Ban map: kept, but quieter -->
  <section class="content-lazy container-x py-12" aria-labelledby="map-heading">
    <div class="mx-auto max-w-4xl">
      <h2 id="map-heading" class="text-h2 text-center">Where the bans are</h2>
      <p class="mx-auto mt-2 max-w-prose text-center text-ink-muted">
        Tap a state to see what's still legal where you live.
      </p>
      <div class="mt-8">
        <USMap caption={false} />
      </div>
    </div>
  </section>

  <!-- FAQ: compact, SEO-friendly -->
  <section class="content-lazy container-x py-12">
    <h2 class="text-center text-h2">Quick questions</h2>
    <dl class="mx-auto mt-6 max-w-prose divide-y divide-surface-border">
      {faqs.map((f) => (
        <div class="py-5">
          <dt class="font-head text-lg font-medium text-ink">{f.q}</dt>
          <dd class="mt-2 text-ink-muted">{f.a}</dd>
        </div>
      ))}
    </dl>
  </section>

  <!-- Trust line -->
  <section class="container-x">
    <p class="mx-auto max-w-2xl rounded-xl border border-surface-border bg-surface p-5 text-center text-ink-muted">
      Not a casino. Nobody pays us to rank them higher.
      <a href="/methodology" class="text-accent hover:underline">How we decide →</a>
    </p>
  </section>

  <!-- Email capture -->
  <section id="alerts" class="container-x py-16">
    <EmailCapture
      variant="panel"
      headline="Heads up when things change?"
      subline="New places to play, new bans, status changes. We'll let you know."
      source="homepage-footer"
    />
  </section>
</Base>

<script>
  const form = document.getElementById('state-picker');
  const select = document.getElementById('state-select');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const slug = (select instanceof HTMLSelectElement) ? select.value : '';
    if (slug) window.location.href = `/state/${slug}`;
  });
</script>
