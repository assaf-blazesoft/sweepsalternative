---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../config';
import { breadcrumbSchema } from '../lib/schema';

const title = `Terms of Use | ${SITE.name}`;
const description = `The terms governing your use of ${SITE.name}, including our informational-only disclaimer.`;
const crumbs = [{ name: 'Home', path: '/' }, { name: 'Terms', path: '/terms' }];
---
<Base title={title} description={description} schema={[breadcrumbSchema(crumbs)]} canonical="/terms">
  <Breadcrumbs crumbs={crumbs} />
  <article class="container-x py-10">
    <div class="prose-content mx-auto max-w-prose">
      <p class="mono-meta uppercase tracking-widest text-accent">Legal</p>
      <h1 class="mt-3 font-head text-h1 text-ink">Terms of use</h1>
      <p class="mt-2 mono-meta">Last updated 2026-05-26</p>

      <blockquote>
        This is a starting-point terms template. Have it reviewed by qualified legal counsel before
        launch to ensure it fits your jurisdiction and business.
      </blockquote>

      <h2>Informational only, not legal or gambling advice</h2>
      <p>
        {SITE.name} is an independent informational resource. Nothing on this site is legal advice,
        financial advice, or gambling advice. Laws governing sweepstakes, gaming, wagering, and
        related activities vary by state and change frequently. <strong>You are responsible for
        confirming what is legal where you live before participating in any platform.</strong> Always
        verify a platform's current legal status directly before signing up.
      </p>

      <h2>Accuracy and changes</h2>
      <p>
        We work to keep information accurate and current, and we date our entries accordingly. But
        the legal landscape moves quickly, and we cannot guarantee that every detail is up to date at
        the moment you read it. Information is provided "as is," without warranties of any kind.
      </p>

      <h2>Third-party platforms and links</h2>
      <p>
        We link to third-party platforms, including via affiliate links (see our
        <a href="/affiliate-disclosure">affiliate disclosure</a>). We don't operate those platforms
        and aren't responsible for their content, terms, or conduct. Your dealings with any
        third-party platform are solely between you and that platform.
      </p>

      <h2>Limitation of liability</h2>
      <p>
        To the fullest extent permitted by law, {SITE.name} is not liable for any losses or damages
        arising from your use of this site or your use of any third-party platform you find through
        it.
      </p>

      <h2>Eligibility</h2>
      <p>
        This site is intended for adults of legal age in their jurisdiction. Many platforms we
        discuss involve real money and have their own age and eligibility requirements.
      </p>

      <h2>Contact</h2>
      <p>Questions? Email <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>.</p>
    </div>
  </article>
</Base>
