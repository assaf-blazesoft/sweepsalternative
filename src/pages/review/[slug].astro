---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VerdictCard from '../../components/VerdictCard.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import { PLATFORM_BY_SLUG, RISK_META } from '../../data/platforms';
import { SITE } from '../../config';
import { reviewSchema, faqSchema, breadcrumbSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const entries = await getCollection('reviews');
  return entries.map((entry) => ({
    params: { slug: entry.data.platform },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const p = PLATFORM_BY_SLUG[entry.data.platform];
const { Content } = await render(entry);

const path = `/review/${p.slug}`;
const title = `${p.name} Review: Legal Alternative for Banned-State Players (2026) | ${SITE.name}`;
const description = `Is ${p.name} legal where you live? Our independent review covers the legal model, California and New York availability, risk level, and how to sign up.`;

const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Alternatives', path: '/alternatives' },
  { name: p.name, path },
];

const related = entry.data.related
  .map((slug) => PLATFORM_BY_SLUG[slug])
  .filter(Boolean);

const schema = [
  reviewSchema({ name: p.name, description: entry.data.verdict, path }),
  faqSchema(entry.data.faqs),
  breadcrumbSchema(crumbs),
];
---
<Base title={title} description={description} ogType="article" schema={schema} canonical={path}>
  <Breadcrumbs crumbs={crumbs} />
  <AffiliateDisclosure />

  <article class="container-x py-10">
    <div class="mx-auto max-w-prose">
      {p.unconfirmed && (
        <p class="mb-6 rounded-lg border border-amber-400/40 bg-amber-400/5 px-4 py-3 text-sm text-amber-200">
          ⚠ {p.name}'s legal model is not yet confirmed. Treat the assessment below as provisional
          and verify the platform's current status in your state before signing up.
        </p>
      )}

      <p class="mono-meta uppercase tracking-widest text-accent">Platform review</p>
      <h1 class="mt-3 text-h1">{p.name} Review: Legal Alternatives for Banned-State Players (2026)</h1>

      <div class="mt-8">
        <VerdictCard platform={p} verdict={entry.data.verdict} />
      </div>

      <div class="prose-content mt-12">
        <Content />
      </div>

      <!-- Pros & cons -->
      <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2">
        <div class="card p-6">
          <h2 class="font-head text-lg font-semibold text-emerald-400">Pros</h2>
          <ul class="mt-3 space-y-2 text-sm text-ink-muted">
            {entry.data.pros.map((pro) => <li class="flex gap-2"><span class="text-emerald-400">+</span>{pro}</li>)}
          </ul>
        </div>
        <div class="card p-6">
          <h2 class="font-head text-lg font-semibold text-red-400">Cons</h2>
          <ul class="mt-3 space-y-2 text-sm text-ink-muted">
            {entry.data.cons.map((con) => <li class="flex gap-2"><span class="text-red-400">−</span>{con}</li>)}
          </ul>
        </div>
      </div>

      <!-- Repeat CTA -->
      <div class="mt-10 flex flex-col items-start gap-3 rounded-xl border border-surface-border bg-surface p-6 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="font-head text-lg font-semibold text-ink">Ready to try {p.name}?</p>
          <p class="mono-meta mt-1">
            <span class="inline-block h-2 w-2 rounded-full align-middle" style={`background:${RISK_META[p.risk].color}`}></span>
            {RISK_META[p.risk].label} risk · Last verified {p.lastVerified}
          </p>
        </div>
        <a href={p.outboundUrl} target="_blank" rel={p.affiliate ? 'nofollow sponsored noopener' : 'noopener'} class="btn-primary px-6 py-3">
          Visit {p.name} ↗
        </a>
      </div>

      {related.length > 0 && (
        <section class="mt-12">
          <h2 class="font-head text-h3 text-ink">Alternatives to {p.name}</h2>
          <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-3">
            {related.map((r) => (
              <a href={`/review/${r.slug}`} class="card card-hover flex items-center gap-3 p-4">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-surface-border bg-white/5 font-head text-xs font-bold">
                  {r.logoUrl
                    ? <img src={r.logoUrl} alt={`${r.name} logo`} width="36" height="36" loading="lazy" decoding="async" class="h-full w-full object-contain" />
                    : r.initials}
                </span>
                <span class="font-medium text-ink">{r.name}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      {entry.data.faqs.length > 0 && (
        <section class="mt-12">
          <h2 class="font-head text-h2 text-ink">Frequently asked questions</h2>
          <dl class="mt-6 divide-y divide-surface-border">
            {entry.data.faqs.map((f) => (
              <div class="py-5">
                <dt class="font-head text-lg font-medium text-ink">{f.q}</dt>
                <dd class="mt-2 text-ink-muted">{f.a}</dd>
              </div>
            ))}
          </dl>
        </section>
      )}

      <p class="mt-12 mono-meta border-t border-surface-border pt-6">
        Last updated {entry.data.lastUpdated} · {SITE.name} maintains editorial independence.
        This is not legal advice, verify {p.name}'s status in your state before signing up.
      </p>
    </div>
  </article>
</Base>
