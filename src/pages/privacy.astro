---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../config';
import { breadcrumbSchema } from '../lib/schema';

const title = `Privacy Policy | ${SITE.name}`;
const description = `How ${SITE.name} handles your data, email signups, and analytics.`;
const crumbs = [{ name: 'Home', path: '/' }, { name: 'Privacy', path: '/privacy' }];
---
<Base title={title} description={description} schema={[breadcrumbSchema(crumbs)]} canonical="/privacy">
  <Breadcrumbs crumbs={crumbs} />
  <article class="container-x py-10">
    <div class="prose-content mx-auto max-w-prose">
      <p class="mono-meta uppercase tracking-widest text-accent">Legal</p>
      <h1 class="mt-3 font-head text-h1 text-ink">Privacy policy</h1>
      <p class="mt-2 mono-meta">Last updated 2026-05-26</p>

      <blockquote>
        This is a starting-point privacy policy template. Have it reviewed by qualified legal counsel
        and finalized to match your actual data practices and the email/analytics providers you
        choose before launch.
      </blockquote>

      <h2>What we collect</h2>
      <ul>
        <li><strong>Email address</strong>, only if you choose to subscribe. We use it to send updates about platform and legal-status changes.</li>
        <li><strong>Optional state</strong>, if you provide it, we use it to tailor the updates we send you.</li>
        <li><strong>Privacy-respecting analytics</strong>, we use aggregate, cookieless analytics to understand traffic. We do not build advertising profiles of you.</li>
      </ul>

      <h2>What we don't do</h2>
      <ul>
        <li>We don't sell your personal information.</li>
        <li>We don't require an account to read anything on this site.</li>
        <li>We don't use invasive third-party advertising trackers.</li>
      </ul>

      <h2>Email and unsubscribing</h2>
      <p>
        Every email we send includes a one-click unsubscribe link. You can opt out at any time, and
        we'll remove your address from our list.
      </p>

      <h2>Your rights</h2>
      <p>
        Depending on where you live, you may have rights to access, correct, or delete the personal
        data we hold about you. To exercise them, email
        <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>.
      </p>

      <h2>Contact</h2>
      <p>Questions about this policy? Email <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>.</p>
    </div>
  </article>
</Base>
